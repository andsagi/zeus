{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "language": { "type": "string", "enum": ["pt", "en"] },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "specialization": { "type": "string", "description": "User's professional field (e.g., Civil Engineer)" },
        "trialStartDate": { "type": "string", "format": "date-time" },
        "subscriptionStatus": { "type": "string", "enum": ["trial", "active", "expired"] },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "address": { "type": "string" },
              "category": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Page": {
      "title": "Workspace Page",
      "description": "A document or board within the workspace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isFavorite": { "type": "boolean" },
        "type": { "type": "string", "enum": ["note", "table", "dashboard"] }
      },
      "required": ["id", "title", "ownerId"]
    },
    "AIConversation": {
      "title": "AI Interaction",
      "description": "History of AI assistant messages",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Main user records"
    },
    "pages/{pageId}": {
      "schema": "Page",
      "description": "Workspace documents"
    },
    "users/{userId}/conversations/{convId}": {
      "schema": "AIConversation",
      "description": "AI memory per user"
    }
  }
}
