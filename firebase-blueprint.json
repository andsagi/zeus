{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "language": { "type": "string", "enum": ["pt", "en"] },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "specialization": { "type": "string", "description": "User's professional field (e.g., Civil Engineer)" },
        "trialStartDate": { "type": "string", "format": "date-time" },
        "subscriptionStatus": { "type": "string", "enum": ["trial", "active", "expired", "premium"] },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "address": { "type": "string" },
              "category": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Page": {
      "title": "Workspace Page",
      "description": "A document or board within the workspace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isFavorite": { "type": "boolean" },
        "type": { "type": "string", "enum": ["note", "table", "dashboard"] }
      },
      "required": ["id", "title", "ownerId"]
    },
    "Note": {
      "title": "User Note",
      "description": "A piece of text saved by the user",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "priority": { "type": "boolean" }
      },
      "required": ["title", "content"]
    },
    "AIMessage": {
      "title": "AI Message",
      "description": "An individual message in the AI chat history",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uri": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        }
      },
      "required": ["role", "text", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Main user records"
    },
    "pages/{pageId}": {
      "schema": "Page",
      "description": "Workspace documents"
    },
    "users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User saved notes"
    },
    "users/{userId}/messages/{msgId}": {
      "schema": "AIMessage",
      "description": "Individual messages for history"
    }
  }
}
